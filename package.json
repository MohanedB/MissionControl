{
  "name": "mission-control",
  "version": "1.0.0",
  "description": "OpenClaw Mission Control Dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --watch server.js --watch lib -e js,json server.js",
    "stop": "node -e \"const {execSync}=require('child_process');try{const out=execSync('netstat -ano').toString();const m=out.match(/TCP[\\s\\S]*?:3000\\s.*LISTENING\\s+(\\d+)/);if(m){execSync('taskkill /PID '+m[1]+' /F');console.log('Stopped PID',m[1]);}else console.log('Not running');}catch(e){console.error(e.message);}\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
